# Anthropic
ANTHROPIC_API_KEY=

# Search
SERPER_API_KEY=

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=esg-reporting-agent

# Google Drive integration
# Create an OAuth client in Google Cloud Console (Web application type) and
# put its values here. See backend/routers/google_auth.py for the flow.
SPRIH_GOOGLE_OAUTH_CLIENT_ID=
SPRIH_GOOGLE_OAUTH_CLIENT_SECRET=
SPRIH_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Auth (dev mode skips JWT and uses a default enterprise)
SPRIH_AUTH_DEV_MODE=true
SPRIH_DEFAULT_ENTERPRISE_ID=sprih
SPRIH_DEFAULT_ENTERPRISE_NAME=Sprih

# Open-terminal container
OPEN_TERMINAL_URL=http://localhost:8001
OPEN_TERMINAL_API_KEY=
# Base directory inside the open-terminal container. A per-thread subdirectory
# ({base}/{thread_id}) is appended at runtime so each thread is sandboxed to
# its own workspace and commands start there by default.
OPEN_TERMINAL_WORKDIR=/workspace
