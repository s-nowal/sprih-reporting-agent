# Empty BASE_URL → API calls are same-origin relative paths.
# Vite reverse-proxies them to the FastAPI backend (see vite.config.js).
# Override only if you want to point the plugin at a different host.
VITE_API_BASE_URL=
HTTPS_CERT_FILE=C:\Users\Vinay Nowal\.office-addin-dev-certs\localhost.crt
HTTPS_KEY_FILE=C:\Users\Vinay Nowal\.office-addin-dev-certs\localhost.key
